# Server Configuration
PORT=4006

# Service Behavior
APP_URL=http://localhost:3000
EMAIL_PROVIDER=logging
DEFAULT_FROM_EMAIL=no-reply@socialmedia.local

# SendGrid (used when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@socialmedia.local

# Resend (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=social-media.events
RABBITMQ_EMAIL_QUEUE=social-media.email-delivery

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# Logging (Loki/Grafana)
LOGS_TO_LOKI=true
LOKI_HOST=http://localhost
LOKI_PORT=3100
