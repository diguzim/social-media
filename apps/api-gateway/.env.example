# Server Configuration
PORT=4000

# JWT Configuration
JWT_SECRET=your-secret-key-here

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# Rate limiting (IP-based)
THROTTLE_LIMIT=120
THROTTLE_TTL_MS=60000

# Microservice connections
AUTH_SERVICE_HOST=localhost
AUTH_SERVICE_PORT=4001
POSTS_SERVICE_HOST=localhost
POSTS_SERVICE_PORT=4002
IMAGE_SERVICE_HOST=localhost
IMAGE_SERVICE_PORT=4004
EMAIL_SERVICE_HOST=localhost
EMAIL_SERVICE_PORT=4006

# CORS (comma-separated allowlist)
CORS_ORIGINS=http://localhost:3000,https://app.example.com
# Legacy single-origin fallback (optional)
# CORS_ORIGIN=http://localhost:3000

# Logging (Loki/Grafana)
LOGS_TO_LOKI=true
LOKI_HOST=http://localhost
LOKI_PORT=3100
