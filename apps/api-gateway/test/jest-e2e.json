{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "extensionsToTreatAsEsm": [".ts"],
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1",
    "^@repo/contracts$": "<rootDir>/../../../packages/contracts/src/index.ts",
    "^@repo/log-context$": "<rootDir>/../../../packages/log-context/src/index.ts",
    "^@repo/exception-filters$": "<rootDir>/../../../packages/exception-filters/src/index.ts",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "useESM": true,
        "tsconfig": {
          "module": "ESNext",
          "moduleResolution": "nodenext",
          "resolvePackageJsonExports": false
        }
      }
    ]
  }
}
