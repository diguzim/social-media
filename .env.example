# Root environment example
# Copy the relevant section into each service's .env file.

# api-gateway (apps/api-gateway/.env)
API_GATEWAY_PORT=4000
API_GATEWAY_JWT_SECRET=change-me
API_GATEWAY_SENTRY_DSN=
API_GATEWAY_SENTRY_ENVIRONMENT=development
API_GATEWAY_SENTRY_TRACES_SAMPLE_RATE=1.0

# auth-service (apps/auth-service/.env)
AUTH_SERVICE_PORT=4001
AUTH_SERVICE_JWT_SECRET=change-me
AUTH_SERVICE_JWT_EXPIRES_IN=24h
AUTH_SERVICE_SENTRY_DSN=
AUTH_SERVICE_SENTRY_ENVIRONMENT=development
AUTH_SERVICE_SENTRY_TRACES_SAMPLE_RATE=1.0

# posts-service (apps/posts-service/.env)
POSTS_SERVICE_PORT=4002
POSTS_SERVICE_SENTRY_DSN=
POSTS_SERVICE_SENTRY_ENVIRONMENT=development
POSTS_SERVICE_SENTRY_TRACES_SAMPLE_RATE=1.0

# image-service (apps/image-service/.env)
IMAGE_SERVICE_PORT=4004
IMAGE_SERVICE_SENTRY_DSN=
IMAGE_SERVICE_SENTRY_ENVIRONMENT=development
IMAGE_SERVICE_SENTRY_TRACES_SAMPLE_RATE=1.0

# friendship-service (apps/friendship-service/.env)
FRIENDSHIP_SERVICE_PORT=4005
FRIENDSHIP_SERVICE_SENTRY_DSN=
FRIENDSHIP_SERVICE_SENTRY_ENVIRONMENT=development
FRIENDSHIP_SERVICE_SENTRY_TRACES_SAMPLE_RATE=1.0

# event-handler-service (apps/event-handler-service/.env)
EVENT_HANDLER_SERVICE_PORT=4003
EVENT_HANDLER_SERVICE_SENTRY_DSN=
EVENT_HANDLER_SERVICE_SENTRY_ENVIRONMENT=development
EVENT_HANDLER_SERVICE_SENTRY_TRACES_SAMPLE_RATE=1.0

# user-portal (apps/user-portal/.env)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=1.0
