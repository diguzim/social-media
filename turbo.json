{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "AUTH_SERVICE_HOST",
    "AUTH_SERVICE_PORT",
    "CORS_ORIGIN",
    "API_PUBLIC_BASE_URL",
    "FRIENDSHIP_SERVICE_HOST",
    "FRIENDSHIP_SERVICE_PORT",
    "IMAGE_SERVICE_HOST",
    "IMAGE_SERVICE_PORT",
    "IMAGE_STORAGE_DIR",
    "LOGS_TO_LOKI",
    "LOKI_HOST",
    "LOKI_PORT",
    "NODE_ENV",
    "PORT",
    "POSTS_SERVICE_HOST",
    "POSTS_SERVICE_PORT",
    "RABBITMQ_EXCHANGE",
    "RABBITMQ_URL",
    "RABBITMQ_USER_REGISTERED_QUEUE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "dist/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "e2e": {
      "cache": false,
      "inputs": ["cypress/**", "*.ts", ".env*"]
    }
  }
}
