{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "AUTH_SERVICE_HOST",
    "AUTH_SERVICE_PORT",
    "DEFAULT_FROM_EMAIL",
    "CORS_ORIGINS",
    "CORS_ORIGIN",
    "EMAIL_PROVIDER",
    "EMAIL_SERVICE_HOST",
    "EMAIL_SERVICE_PORT",
    "API_PUBLIC_BASE_URL",
    "EVENT_HANDLER_ENABLE_USER_EMAIL_HANDLERS",
    "FRIENDSHIP_SERVICE_HOST",
    "FRIENDSHIP_SERVICE_PORT",
    "IMAGE_SERVICE_HOST",
    "IMAGE_SERVICE_PORT",
    "IMAGE_STORAGE_DIR",
    "LOGS_TO_LOKI",
    "LOKI_HOST",
    "LOKI_PORT",
    "NODE_ENV",
    "PORT",
    "POSTS_SERVICE_HOST",
    "POSTS_SERVICE_PORT",
    "RABBITMQ_EXCHANGE",
    "RABBITMQ_EMAIL_QUEUE",
    "RABBITMQ_URL",
    "RABBITMQ_USER_REGISTERED_QUEUE",
    "SENDGRID_API_KEY",
    "SENDGRID_FROM_EMAIL",
    "SENTRY_DSN",
    "SENTRY_ENVIRONMENT",
    "SENTRY_TRACES_SAMPLE_RATE",
    "THROTTLE_LIMIT",
    "THROTTLE_TTL_MS",
    "VITE_SENTRY_DSN",
    "VITE_SENTRY_ENVIRONMENT",
    "VITE_SENTRY_TRACES_SAMPLE_RATE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "dist/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "e2e": {
      "cache": false,
      "inputs": ["cypress/**", "*.ts", ".env*"]
    }
  }
}
